#include <SPI.h>
#include <nRF24L01.h>
#include <RF24.h>

#define CSN_GPIO        8
#define CE_GPIO         7

#define RIGHT_FORWARD   5
#define RIGHT_BACKWARD  4
#define LEFT_FORWARD    3
#define LEFT_BACKWARD   2
#define LED             6

RF24 radio(CE_GPIO, CSN_GPIO);

const byte Address[6] = "00001";
unsigned char Received_Command = 0, Speed_index = 0, Run_Stop_Mode = 0;
unsigned char Rx_Array[2];
unsigned int Run_Stop_Counter = 0;

void setup() {
  Serial.begin(115200);
  pinMode(RIGHT_FORWARD, OUTPUT);
  pinMode(RIGHT_BACKWARD, OUTPUT);
  pinMode(LEFT_FORWARD, OUTPUT);
  pinMode(LEFT_BACKWARD, OUTPUT);
  pinMode(LED, OUTPUT);

  radio.begin();
  radio.setChannel(76);
  radio.setPALevel(RF24_PA_MAX);
  radio.openReadingPipe(1, Address);
  radio.startListening();

  Serial.println("--- Receiver Ready ---");

  for(int i = 0; i < 3; i++) {
    digitalWrite(LED, HIGH); delay(100);
    digitalWrite(LED, LOW);  delay(100);
  }
}

void loop()
{
  if(radio.available())
  {
    delay(1);
    radio.read(&Rx_Array, 2);
    Received_Command = Rx_Array[0];
    Speed_index = Rx_Array[1];

    for(int i = 0; i < 2; i++) {
      digitalWrite(LED, HIGH); delay(50);
      digitalWrite(LED, LOW);  delay(50);
    }

    Serial.print("CMD: "); Serial.print(Received_Command);
    Serial.print(" | Dir: ");
    switch(Received_Command) {
      case 0: Serial.print("STOP    "); break;
      case 1: Serial.print("FORWARD "); break;
      case 2: Serial.print("BACKWARD"); break;
      case 3: Serial.print("LEFT    "); break;
      case 4: Serial.print("RIGHT   "); break;
      default: Serial.print("UNKNOWN "); break;
    }
    Serial.print(" | Speed: "); Serial.print(Speed_index);
    Serial.println(" | RX: OK");
  }

  if(Run_Stop_Mode == 0)
  {
    digitalWrite(RIGHT_FORWARD, LOW);
    digitalWrite(RIGHT_BACKWARD, LOW);
    digitalWrite(LEFT_FORWARD, LOW);
    digitalWrite(LEFT_BACKWARD, LOW);
    Run_Stop_Counter++;
    if(Run_Stop_Counter >= ((5 - Speed_index) * 100))
    {
      Run_Stop_Counter = 0;
      Run_Stop_Mode = 1;
    }
  }
  else if(Run_Stop_Mode == 1)
  {
    Run_Stop_Counter++;
    if(Run_Stop_Counter >= ((Speed_index) * 100))
    {
      Run_Stop_Counter = 0;
      Run_Stop_Mode = 0;
    }

    if(Received_Command == 1)
    {
      digitalWrite(LEFT_FORWARD, HIGH);
      digitalWrite(RIGHT_FORWARD, HIGH);
    }
    else if(Received_Command == 2)
    {
      digitalWrite(LEFT_BACKWARD, HIGH);
      digitalWrite(RIGHT_BACKWARD, HIGH);
    }
    else if(Received_Command == 3)
    {
      digitalWrite(LEFT_FORWARD, HIGH);
      digitalWrite(RIGHT_BACKWARD, HIGH);
    }
    else if(Received_Command == 4)
    {
      digitalWrite(RIGHT_FORWARD, HIGH);
      digitalWrite(LEFT_BACKWARD, HIGH);
    }
    else
    {
      digitalWrite(RIGHT_FORWARD, LOW);
      digitalWrite(RIGHT_BACKWARD, LOW);
      digitalWrite(LEFT_FORWARD, LOW);
      digitalWrite(LEFT_BACKWARD, LOW);
    }
  }
}
